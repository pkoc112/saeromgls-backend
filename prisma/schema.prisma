// ============================================
// 새롬 GLS 작업현황 공유 시스템 - Prisma Schema
// ============================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Models ----------

/// 사업장 - 멀티테넌트 단위
model Site {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique
  isActive     Boolean  @default(true) @map("is_active")
  parentSiteId String?  @map("parent_site_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  parentSite         Site?              @relation("SiteHierarchy", fields: [parentSiteId], references: [id])
  childSites         Site[]             @relation("SiteHierarchy")
  workers            Worker[]
  breakConfigs       BreakConfig[]
  insights           DashboardInsight[]
  subscriptions      Subscription[]
  classifications    Classification[]
  incentivePolicies  IncentivePolicy[]
  dashboardGoals     DashboardGoal[]
  activityLogs       AdminActivityLog[]
  backupJobs         BackupJob[]
  restoreRequests    RestoreRequest[]
  inspectionRecords  InspectionRecord[]
  inboundSessions    InboundSession[]
  dockSessions       DockSession[]
  policyVersions     PolicyVersion[]
  baselineSnapshots  BaselineSnapshot[]
  scoreRuns          ScoreRun[]
  objectionCases     ObjectionCase[]
  approvalLogs       ApprovalLog[]
  payoutBatches      PayoutBatch[]
  predictionLogs     PredictionLog[]
  tenantSettings     TenantSettings?
  onboardingRuns     OnboardingRun[]
  supportCases       SupportCase[]
  usageSnapshots     UsageSnapshot[]

  @@index([parentSiteId])
  @@map("sites")
}

/// 휴게시간 설정
model BreakConfig {
  id        String   @id @default(uuid())
  siteId    String?  @map("site_id")
  label     String
  startHour Int      @map("start_hour")
  startMin  Int      @map("start_min")
  endHour   Int      @map("end_hour")
  endMin    Int      @map("end_min")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  site Site? @relation(fields: [siteId], references: [id])

  @@index([siteId])
  @@map("break_configs")
}

/// 이용 동의 기록
model UserConsent {
  id          String   @id @default(uuid())
  workerId    String   @map("worker_id")
  consentType String   @map("consent_type")
  version     String   @default("1.0")
  agreedAt    DateTime @default(now()) @map("agreed_at")
  ipAddress   String?  @map("ip_address")

  worker Worker @relation(fields: [workerId], references: [id])

  @@index([workerId])
  @@map("user_consents")
}

/// 작업자 - 시스템 사용자
model Worker {
  id             String   @id @default(uuid())
  name           String
  employeeCode   String   @unique @map("employee_code")
  pin            String
  email          String?  @unique
  phone          String?
  passwordHash   String?  @map("password_hash")
  emailVerified  Boolean  @default(false) @map("email_verified")
  role           String   @default("WORKER")
  status         String   @default("ACTIVE")
  mobileVisible  Boolean  @default(true) @map("mobile_visible")
  jobTrack       String?  @map("job_track") // OUTBOUND_RANKED, INBOUND_SUPPORT, INSPECTION_GOAL, DOCK_WRAP_GOAL, MANAGER_OPS
  siteId         String?  @map("site_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  site             Site?            @relation(fields: [siteId], references: [id])
  startedWorkItems WorkItem[]       @relation("StartedBy")
  endedWorkItems   WorkItem[]       @relation("EndedBy")
  assignments      WorkAssignment[]
  auditLogs        AuditLog[]
  consents         UserConsent[]
  loginHistory     LoginHistory[]
  activityLogs     AdminActivityLog[]
  restoreRequests    RestoreRequest[]
  refreshTokens      RefreshToken[]
  inspections        InspectionRecord[] @relation("InspectedBy")
  approvedInbounds   InboundSession[]   @relation("ApprovedInbound")
  inboundParticipations InboundParticipant[] @relation("InboundParticipant")
  dockSessions       DockSession[]      @relation("DockStartedBy")
  dockParticipations DockParticipant[]  @relation("DockParticipant")
  scoreEntries       ScoreEntry[]       @relation("ScoreEntries")
  objections         ObjectionCase[]    @relation("Objections")
  payoutEntries      PayoutEntry[]      @relation("PayoutEntries")

  @@index([siteId])
  @@index([status, role])
  @@map("workers")
}

/// 분류 - 작업 분류 코드
model Classification {
  id          String   @id @default(uuid())
  code        String   @unique
  displayName String   @map("display_name")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  siteId      String?  @map("site_id")
  createdAt   DateTime @default(now()) @map("created_at")

  site      Site?      @relation(fields: [siteId], references: [id])
  workItems WorkItem[]

  @@index([siteId])
  @@map("classifications")
}

/// 작업 항목
model WorkItem {
  id                String   @id @default(uuid())
  startedByWorkerId String   @map("started_by_worker_id")
  classificationId  String   @map("classification_id")
  volume            Decimal  @default(0) @db.Decimal(10, 2)
  quantity          Int      @default(0)
  startedAt         DateTime @default(now()) @map("started_at")
  endedAt           DateTime? @map("ended_at")
  status            String   @default("ACTIVE")
  endedByWorkerId   String?  @map("ended_by_worker_id")
  deviceId          String?  @map("device_id")
  notes             String?
  idempotencyKey    String?  @unique @map("idempotency_key")
  batchId           String?  @map("batch_id")
  jobType           String   @default("OUTBOUND") @map("job_type")
  metricMode        String   @default("INDIVIDUAL") @map("metric_mode")
  scoreEligible     Boolean  @default(true) @map("score_eligible")
  sourceWorkItemId  String?  @map("source_work_item_id")
  sessionKey        String?  @map("session_key")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  startedByWorker  Worker          @relation("StartedBy", fields: [startedByWorkerId], references: [id])
  endedByWorker    Worker?         @relation("EndedBy", fields: [endedByWorkerId], references: [id])
  classification   Classification  @relation(fields: [classificationId], references: [id])
  sourceWorkItem   WorkItem?       @relation("SourceRef", fields: [sourceWorkItemId], references: [id])
  derivedItems     WorkItem[]      @relation("SourceRef")
  assignments      WorkAssignment[]
  auditLogs        AuditLog[]
  inspections      InspectionRecord[]

  @@index([status])
  @@index([startedAt])
  @@index([classificationId])
  @@index([startedByWorkerId])
  @@index([startedAt, status])
  @@index([classificationId, status])
  @@index([startedByWorkerId, status])
  @@index([endedByWorkerId])
  @@index([batchId])
  @@map("work_items")
}

/// 작업 배정
model WorkAssignment {
  id         String   @id @default(uuid())
  workItemId String   @map("work_item_id")
  workerId   String   @map("worker_id")
  role       String   @default("PARTICIPANT")
  addedAt    DateTime @default(now()) @map("added_at")

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  worker   Worker   @relation(fields: [workerId], references: [id])

  @@unique([workItemId, workerId])
  @@index([workerId])
  @@map("work_assignments")
}

/// 감사 로그
model AuditLog {
  id            String   @id @default(uuid())
  actorWorkerId String   @map("actor_worker_id")
  workItemId    String?  @map("work_item_id")
  action        String
  before        String?
  after         String?
  reason        String?
  ip            String?
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at")

  actorWorker Worker    @relation(fields: [actorWorkerId], references: [id])
  workItem    WorkItem? @relation(fields: [workItemId], references: [id], onDelete: SetNull)

  @@index([workItemId])
  @@index([actorWorkerId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// AI 인사이트
model DashboardInsight {
  id          String   @id @default(uuid())
  type        String
  period      String
  content     String
  siteId      String?  @map("site_id")
  generatedAt DateTime @map("generated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  site Site? @relation(fields: [siteId], references: [id])

  @@index([type])
  @@index([generatedAt])
  @@index([siteId])
  @@map("dashboard_insights")
}

/// 구독 플랜
model Plan {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique
  maxWorkers   Int      @map("max_workers")
  maxSites     Int      @default(1) @map("max_sites")
  features     String[]
  priceMonthly Int      @default(0) @map("price_monthly")
  priceYearly  Int      @default(0) @map("price_yearly")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  subscriptions Subscription[]
  @@map("plans")
}

/// 사업장 구독
model Subscription {
  id                 String   @id @default(uuid())
  siteId             String   @map("site_id")
  planId             String   @map("plan_id")
  status             String   @default("ACTIVE")
  billingCycle       String   @default("MONTHLY") @map("billing_cycle")
  trialEndsAt        DateTime? @map("trial_ends_at")
  currentPeriodStart DateTime @default(now()) @map("current_period_start")
  currentPeriodEnd   DateTime @map("current_period_end")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@index([siteId])
  @@index([status])
  @@map("subscriptions")
}

/// 로그인 이력
model LoginHistory {
  id        String   @id @default(uuid())
  workerId  String   @map("worker_id")
  success   Boolean
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  worker Worker @relation(fields: [workerId], references: [id])

  @@index([workerId])
  @@index([createdAt])
  @@index([workerId, createdAt])
  @@map("login_history")
}

/// 인센티브 정책
model IncentivePolicy {
  id                  String   @id @default(uuid())
  siteId              String   @map("site_id")
  name                String
  scoreWeightCount    Float    @default(10) @map("score_weight_count")
  scoreWeightVolume   Float    @default(2) @map("score_weight_volume")
  scoreWeightQuantity Float    @default(0.05) @map("score_weight_quantity")
  bonusThreshold1     Float?   @map("bonus_threshold_1")
  bonusAmount1        Int?     @map("bonus_amount_1")
  bonusThreshold2     Float?   @map("bonus_threshold_2")
  bonusAmount2        Int?     @map("bonus_amount_2")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId])
  @@map("incentive_policies")
}

/// 대시보드 목표
model DashboardGoal {
  id             String   @id @default(uuid())
  siteId         String   @map("site_id")
  periodType     String   // daily, weekly, monthly
  targetCount    Int      @default(0) @map("target_count")
  targetVolume   Decimal  @default(0) @map("target_volume") @db.Decimal(10, 2)
  targetQuantity Int      @default(0) @map("target_quantity")
  createdAt      DateTime @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId])
  @@map("dashboard_goals")
}

/// 관리자 활동 로그
model AdminActivityLog {
  id              String   @id @default(uuid())
  siteId          String?  @map("site_id")
  actorWorkerId   String   @map("actor_worker_id")
  actionType      String   @map("action_type")
  targetType      String?  @map("target_type")
  targetId        String?  @map("target_id")
  metadata        String?
  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent")
  createdAt       DateTime @default(now()) @map("created_at")

  site            Site?    @relation(fields: [siteId], references: [id])
  actorWorker     Worker   @relation(fields: [actorWorkerId], references: [id])

  @@index([siteId])
  @@index([actorWorkerId])
  @@index([actionType])
  @@index([createdAt])
  @@index([siteId, createdAt])
  @@map("admin_activity_logs")
}

/// 리프레시 토큰 (순환 + 재사용 차단)
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  workerId  String   @map("worker_id")
  family    String   @default(uuid())
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  worker Worker @relation(fields: [workerId], references: [id])

  @@index([workerId])
  @@index([token])
  @@index([family])
  @@map("refresh_tokens")
}

/// 이메일 인증 코드 (서버리스 호환 - DB 저장)
model VerificationCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("verification_codes")
}

/// 백업 작업
model BackupJob {
  id          String    @id @default(uuid())
  siteId      String?   @map("site_id")
  type        String    @default("manual")
  status      String    @default("pending")
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  metadata    String?
  createdAt   DateTime  @default(now()) @map("created_at")

  site        Site?     @relation(fields: [siteId], references: [id])

  @@index([siteId])
  @@map("backup_jobs")
}

/// 복원 요청
model RestoreRequest {
  id                  String    @id @default(uuid())
  siteId              String    @map("site_id")
  requestedByWorkerId String    @map("requested_by_worker_id")
  reason              String
  status              String    @default("requested")
  createdAt           DateTime  @default(now()) @map("created_at")
  resolvedAt          DateTime? @map("resolved_at")

  site                Site      @relation(fields: [siteId], references: [id])
  requestedBy         Worker    @relation(fields: [requestedByWorkerId], references: [id])

  @@index([siteId])
  @@map("restore_requests")
}

// ================================================================
// L2. Job Modules
// ================================================================

/// 검수 기록 (출고 작업 참조)
model InspectionRecord {
  id                  String   @id @default(uuid())
  siteId              String   @map("site_id")
  sourceWorkItemId    String   @map("source_work_item_id")
  inspectedByWorkerId String   @map("inspected_by_worker_id")
  result              String   @default("PASS") // PASS, ISSUE, RECHECK
  issueType           String?  @map("issue_type")
  quantityChecked     Int      @default(0) @map("quantity_checked")
  quantityDefect      Int      @default(0) @map("quantity_defect")
  notes               String?
  inspectedAt         DateTime @default(now()) @map("inspected_at")
  createdAt           DateTime @default(now()) @map("created_at")

  site          Site     @relation(fields: [siteId], references: [id])
  sourceWorkItem WorkItem @relation(fields: [sourceWorkItemId], references: [id])
  inspectedBy   Worker   @relation("InspectedBy", fields: [inspectedByWorkerId], references: [id])

  @@index([siteId])
  @@index([sourceWorkItemId])
  @@index([inspectedByWorkerId])
  @@index([inspectedAt])
  @@map("inspection_records")
}

/// 입고 세션 (관리자 승인형 총량)
model InboundSession {
  id                String    @id @default(uuid())
  siteId            String    @map("site_id")
  sessionDate       DateTime  @map("session_date")
  shift             String    @default("AM") // AM, PM, FULL
  supplierName      String?   @map("supplier_name")
  totalQuantity     Int       @default(0) @map("total_quantity")
  totalVolume       Decimal   @default(0) @db.Decimal(10, 2) @map("total_volume")
  itemCount         Int       @default(0) @map("item_count")
  expectedQuantity  Int       @default(0) @map("expected_quantity")
  diffQuantity      Int       @default(0) @map("diff_quantity")
  status            String    @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedByWorkerId String?  @map("approved_by_worker_id")
  approvedAt        DateTime? @map("approved_at")
  startedAt         DateTime? @map("started_at")
  endedAt           DateTime? @map("ended_at")
  notes             String?
  rawData           String?   @map("raw_data") // 업로드된 엑셀 JSON
  createdAt         DateTime  @default(now()) @map("created_at")

  site       Site    @relation(fields: [siteId], references: [id])
  approvedBy Worker? @relation("ApprovedInbound", fields: [approvedByWorkerId], references: [id])
  participants InboundParticipant[]

  @@index([siteId])
  @@index([sessionDate])
  @@index([status])
  @@map("inbound_sessions")
}

/// 입고 세션 참여자
model InboundParticipant {
  id              String @id @default(uuid())
  inboundSessionId String @map("inbound_session_id")
  workerId        String @map("worker_id")

  session InboundSession @relation(fields: [inboundSessionId], references: [id], onDelete: Cascade)
  worker  Worker         @relation("InboundParticipant", fields: [workerId], references: [id])

  @@unique([inboundSessionId, workerId])
  @@map("inbound_participants")
}

/// 상하차/랩핑 세션 (도크 단위)
model DockSession {
  id              String    @id @default(uuid())
  siteId          String    @map("site_id")
  actionType      String    @default("LOAD") // LOAD, UNLOAD
  dockNumber      String?   @map("dock_number")
  vehicleNumber   String?   @map("vehicle_number")
  totalQuantity   Int       @default(0) @map("total_quantity")
  wrapIncluded    Boolean   @default(false) @map("wrap_included")
  wrapLevel       String?   @map("wrap_level") // NONE, LIGHT, MEDIUM, HEAVY
  status          String    @default("ACTIVE") // ACTIVE, ENDED
  startedByWorkerId String  @map("started_by_worker_id")
  startedAt       DateTime  @default(now()) @map("started_at")
  endedAt         DateTime? @map("ended_at")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  site      Site   @relation(fields: [siteId], references: [id])
  startedBy Worker @relation("DockStartedBy", fields: [startedByWorkerId], references: [id])
  participants DockParticipant[]

  @@index([siteId])
  @@index([startedAt])
  @@index([status])
  @@map("dock_sessions")
}

/// 도크 세션 참여자
model DockParticipant {
  id            String @id @default(uuid())
  dockSessionId String @map("dock_session_id")
  workerId      String @map("worker_id")
  role          String @default("WORKER") // WORKER, WRAPPER

  session DockSession @relation(fields: [dockSessionId], references: [id], onDelete: Cascade)
  worker  Worker      @relation("DockParticipant", fields: [workerId], references: [id])

  @@unique([dockSessionId, workerId])
  @@map("dock_participants")
}

// ================================================================
// L3. Incentive Engine
// ================================================================

/// 정책 버전 (가중치/기준 변경 이력)
model PolicyVersion {
  id          String   @id @default(uuid())
  siteId      String   @map("site_id")
  name        String
  description String?
  track       String   // OUTBOUND_RANKED, INBOUND_SUPPORT, INSPECTION_GOAL, DOCK_WRAP_GOAL, MANAGER_OPS
  weights     String   // JSON: { performance: 60, reliability: 25, teamwork: 15 }
  details     String?  // JSON: 트랙별 세부 가중치
  status      String   @default("DRAFT") // DRAFT, SHADOW, ACTIVE, RETIRED
  effectiveFrom DateTime? @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  approvedBy  String?  @map("approved_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  site      Site        @relation(fields: [siteId], references: [id])
  scoreRuns ScoreRun[]

  @@index([siteId])
  @@index([track])
  @@index([status])
  @@map("policy_versions")
}

/// 기준치 스냅샷 (난이도, 목표값 등 월 단위 고정)
model BaselineSnapshot {
  id        String   @id @default(uuid())
  siteId    String   @map("site_id")
  month     String   // "2026-04"
  type      String   // DIFFICULTY, TARGET, THRESHOLD
  data      String   // JSON: 스냅샷 데이터
  approvedBy String? @map("approved_by")
  createdAt DateTime @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id])

  @@unique([siteId, month, type])
  @@index([siteId])
  @@map("baseline_snapshots")
}

/// 점수 계산 실행
model ScoreRun {
  id              String   @id @default(uuid())
  siteId          String   @map("site_id")
  policyVersionId String   @map("policy_version_id")
  month           String   // "2026-04"
  status          String   @default("RUNNING") // RUNNING, SHADOW, FROZEN, FINALIZED
  totalWorkers    Int      @default(0) @map("total_workers")
  calculatedAt    DateTime @default(now()) @map("calculated_at")
  frozenAt        DateTime? @map("frozen_at")
  finalizedAt     DateTime? @map("finalized_at")
  createdAt       DateTime @default(now()) @map("created_at")

  site          Site           @relation(fields: [siteId], references: [id])
  policyVersion PolicyVersion  @relation(fields: [policyVersionId], references: [id])
  entries       ScoreEntry[]
  payoutBatches PayoutBatch[]

  @@index([siteId])
  @@index([month])
  @@index([status])
  @@index([siteId, month])
  @@map("score_runs")
}

/// 개인별 점수 항목
model ScoreEntry {
  id              String  @id @default(uuid())
  scoreRunId      String  @map("score_run_id")
  workerId        String  @map("worker_id")
  track           String  // 직무 트랙
  performanceScore Decimal @default(0) @db.Decimal(5, 2) @map("performance_score")
  reliabilityScore Decimal @default(0) @db.Decimal(5, 2) @map("reliability_score")
  teamworkScore    Decimal @default(0) @db.Decimal(5, 2) @map("teamwork_score")
  totalScore       Decimal @default(0) @db.Decimal(5, 2) @map("total_score")
  rank            Int?    // 상대평가 트랙만
  details         String? // JSON: 세부 점수 breakdown
  createdAt       DateTime @default(now()) @map("created_at")

  scoreRun ScoreRun @relation(fields: [scoreRunId], references: [id], onDelete: Cascade)
  worker   Worker   @relation("ScoreEntries", fields: [workerId], references: [id])

  @@unique([scoreRunId, workerId])
  @@index([scoreRunId])
  @@index([workerId])
  @@map("score_entries")
}

/// 이의신청
model ObjectionCase {
  id           String    @id @default(uuid())
  scoreEntryId String?   @map("score_entry_id")
  workerId     String    @map("worker_id")
  siteId       String    @map("site_id")
  month        String
  reason       String
  status       String    @default("OPEN") // OPEN, REVIEWING, ACCEPTED, REJECTED
  resolution   String?
  resolvedBy   String?   @map("resolved_by")
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  worker Worker @relation("Objections", fields: [workerId], references: [id])
  site   Site   @relation(fields: [siteId], references: [id])

  @@index([siteId])
  @@index([workerId])
  @@index([month])
  @@index([status])
  @@map("objection_cases")
}

/// 승인 로그
model ApprovalLog {
  id          String   @id @default(uuid())
  siteId      String   @map("site_id")
  entityType  String   @map("entity_type") // SCORE_RUN, PAYOUT_BATCH, POLICY, BASELINE, INBOUND_SESSION
  entityId    String   @map("entity_id")
  action      String   // APPROVE, REJECT, FREEZE, FINALIZE
  actorId     String   @map("actor_id")
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId])
  @@index([entityType, entityId])
  @@map("approval_logs")
}

/// 지급 배치
model PayoutBatch {
  id            String    @id @default(uuid())
  siteId        String    @map("site_id")
  scoreRunId    String    @map("score_run_id")
  month         String
  status        String    @default("DRAFT") // DRAFT, APPROVED, PAID, CANCELLED
  totalAmount   Decimal   @default(0) @db.Decimal(12, 0) @map("total_amount")
  workerCount   Int       @default(0) @map("worker_count")
  baseIncentive Decimal   @default(500000) @db.Decimal(12, 0) @map("base_incentive")
  approvedBy    String?   @map("approved_by")
  approvedAt    DateTime? @map("approved_at")
  paidAt        DateTime? @map("paid_at")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  site     Site          @relation(fields: [siteId], references: [id])
  scoreRun ScoreRun      @relation(fields: [scoreRunId], references: [id])
  entries  PayoutEntry[]

  @@index([siteId])
  @@index([month])
  @@index([status])
  @@index([scoreRunId])
  @@map("payout_batches")
}

/// 개인별 지급 명세 — 분쟁 시 근거 보존용
model PayoutEntry {
  id             String  @id @default(uuid())
  payoutBatchId  String  @map("payout_batch_id")
  workerId       String  @map("worker_id")
  track          String
  totalScore     Decimal @default(0) @db.Decimal(5, 2) @map("total_score")
  grade          String  // A, B, C, D, E
  amount         Decimal @default(0) @db.Decimal(12, 0)
  snapshotBands  String? @map("snapshot_bands") // JSON: 지급 시점 밴드 스냅샷
  note           String?
  createdAt      DateTime @default(now()) @map("created_at")

  payoutBatch PayoutBatch @relation(fields: [payoutBatchId], references: [id], onDelete: Cascade)
  worker      Worker      @relation("PayoutEntries", fields: [workerId], references: [id], onDelete: Restrict)

  @@unique([payoutBatchId, workerId])
  @@index([workerId])
  @@index([payoutBatchId])
  @@map("payout_entries")
}

// ================================================================
// L4. ML Data Foundation
// ================================================================

/// 정책 팩 템플릿
model PolicyPackTemplate {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  tracks      String   // JSON array of track configs
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("policy_pack_templates")
}

/// ML 추천/예측 로그
model PredictionLog {
  id              String   @id @default(uuid())
  siteId          String   @map("site_id")
  modelVersion    String   @map("model_version")
  predictionType  String   @map("prediction_type") // DIFFICULTY, ANOMALY, WORKLOAD, SIMULATION
  inputSnapshot   String   @map("input_snapshot") // JSON
  output          String   // JSON
  confidence      Decimal? @db.Decimal(5, 4)
  approvedBy      String?  @map("approved_by")
  approvalStatus  String   @default("PENDING") @map("approval_status") // PENDING, APPROVED, REJECTED
  approvedAt      DateTime? @map("approved_at")
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId])
  @@index([predictionType])
  @@index([approvalStatus])
  @@map("prediction_logs")
}

// ================================================================
// L5. Customer Operations (Phase 6)
// ================================================================

/// 테넌트 설정 (고객사별 커스텀 설정)
model TenantSettings {
  id        String   @id @default(uuid())
  siteId    String   @unique @map("site_id")
  settings  String   // JSON: custom settings per tenant
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id])

  @@map("tenant_settings")
}

/// 사업장 템플릿 (신규 고객 빠른 세팅)
model SiteTemplate {
  id                  String   @id @default(uuid())
  name                String
  description         String?
  classificationsJson String   @map("classifications_json") // JSON: default classifications
  breakConfigsJson    String   @map("break_configs_json") // JSON: default break configs
  policyPackCode      String?  @map("policy_pack_code")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("site_templates")
}

/// 온보딩 실행 기록
model OnboardingRun {
  id          String    @id @default(uuid())
  siteId      String    @map("site_id")
  step        Int       @default(1)
  totalSteps  Int       @default(9) @map("total_steps")
  status      String    @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED
  notes       String?
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId])
  @@map("onboarding_runs")
}

/// 고객 지원 케이스
model SupportCase {
  id          String    @id @default(uuid())
  siteId      String    @map("site_id")
  reporterId  String?   @map("reporter_id")
  severity    String    @default("P3") // P1, P2, P3
  title       String
  description String?
  status      String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  resolution  String?
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId])
  @@index([status])
  @@index([severity])
  @@map("support_cases")
}

/// 사용량 스냅샷 (고객별 월간 사용량)
model UsageSnapshot {
  id            String   @id @default(uuid())
  siteId        String   @map("site_id")
  month         String   // "2026-04"
  workerCount   Int      @default(0) @map("worker_count")
  workItemCount Int      @default(0) @map("work_item_count")
  totalVolume   Decimal  @default(0) @db.Decimal(12, 2) @map("total_volume")
  totalQuantity Int      @default(0) @map("total_quantity")
  createdAt     DateTime @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id])

  @@unique([siteId, month])
  @@index([siteId])
  @@map("usage_snapshots")
}
