// ============================================
// 새롬 GLS 작업현황 공유 시스템 - Prisma Schema
// ============================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Models ----------

/// 사업장 - 멀티테넌트 단위
model Site {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique
  isActive     Boolean  @default(true) @map("is_active")
  parentSiteId String?  @map("parent_site_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  parentSite      Site?              @relation("SiteHierarchy", fields: [parentSiteId], references: [id])
  childSites      Site[]             @relation("SiteHierarchy")
  workers         Worker[]
  breakConfigs    BreakConfig[]
  insights        DashboardInsight[]
  subscriptions   Subscription[]
  classifications Classification[]

  @@index([parentSiteId])
  @@map("sites")
}

/// 휴게시간 설정
model BreakConfig {
  id        String   @id @default(uuid())
  siteId    String?  @map("site_id")
  label     String
  startHour Int      @map("start_hour")
  startMin  Int      @map("start_min")
  endHour   Int      @map("end_hour")
  endMin    Int      @map("end_min")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  site Site? @relation(fields: [siteId], references: [id])

  @@index([siteId])
  @@map("break_configs")
}

/// 이용 동의 기록
model UserConsent {
  id          String   @id @default(uuid())
  workerId    String   @map("worker_id")
  consentType String   @map("consent_type")
  version     String   @default("1.0")
  agreedAt    DateTime @default(now()) @map("agreed_at")
  ipAddress   String?  @map("ip_address")

  worker Worker @relation(fields: [workerId], references: [id])

  @@index([workerId])
  @@map("user_consents")
}

/// 작업자 - 시스템 사용자
model Worker {
  id             String   @id @default(uuid())
  name           String
  employeeCode   String   @unique @map("employee_code")
  pin            String
  email          String?  @unique
  phone          String?
  passwordHash   String?  @map("password_hash")
  emailVerified  Boolean  @default(false) @map("email_verified")
  role           String   @default("WORKER")
  status         String   @default("ACTIVE")
  siteId         String?  @map("site_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  site             Site?            @relation(fields: [siteId], references: [id])
  startedWorkItems WorkItem[]       @relation("StartedBy")
  endedWorkItems   WorkItem[]       @relation("EndedBy")
  assignments      WorkAssignment[]
  auditLogs        AuditLog[]
  consents         UserConsent[]
  loginHistory     LoginHistory[]

  @@index([siteId])
  @@map("workers")
}

/// 분류 - 작업 분류 코드
model Classification {
  id          String   @id @default(uuid())
  code        String   @unique
  displayName String   @map("display_name")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  siteId      String?  @map("site_id")
  createdAt   DateTime @default(now()) @map("created_at")

  site      Site?      @relation(fields: [siteId], references: [id])
  workItems WorkItem[]

  @@index([siteId])
  @@map("classifications")
}

/// 작업 항목
model WorkItem {
  id                String   @id @default(uuid())
  startedByWorkerId String   @map("started_by_worker_id")
  classificationId  String   @map("classification_id")
  volume            Decimal  @default(0) @db.Decimal(10, 2)
  quantity          Int      @default(0)
  startedAt         DateTime @default(now()) @map("started_at")
  endedAt           DateTime? @map("ended_at")
  status            String   @default("ACTIVE")
  endedByWorkerId   String?  @map("ended_by_worker_id")
  deviceId          String?  @map("device_id")
  notes             String?
  idempotencyKey    String?  @unique @map("idempotency_key")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  startedByWorker Worker          @relation("StartedBy", fields: [startedByWorkerId], references: [id])
  endedByWorker   Worker?         @relation("EndedBy", fields: [endedByWorkerId], references: [id])
  classification  Classification  @relation(fields: [classificationId], references: [id])
  assignments     WorkAssignment[]
  auditLogs       AuditLog[]

  @@index([status])
  @@index([startedAt])
  @@index([classificationId])
  @@index([startedByWorkerId])
  @@index([startedAt, status])
  @@index([classificationId, status])
  @@index([startedByWorkerId, status])
  @@index([endedByWorkerId])
  @@map("work_items")
}

/// 작업 배정
model WorkAssignment {
  id         String   @id @default(uuid())
  workItemId String   @map("work_item_id")
  workerId   String   @map("worker_id")
  role       String   @default("PARTICIPANT")
  addedAt    DateTime @default(now()) @map("added_at")

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  worker   Worker   @relation(fields: [workerId], references: [id])

  @@unique([workItemId, workerId])
  @@index([workerId])
  @@map("work_assignments")
}

/// 감사 로그
model AuditLog {
  id            String   @id @default(uuid())
  actorWorkerId String   @map("actor_worker_id")
  workItemId    String?  @map("work_item_id")
  action        String
  before        String?
  after         String?
  reason        String?
  ip            String?
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at")

  actorWorker Worker    @relation(fields: [actorWorkerId], references: [id])
  workItem    WorkItem? @relation(fields: [workItemId], references: [id], onDelete: SetNull)

  @@index([workItemId])
  @@index([actorWorkerId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// AI 인사이트
model DashboardInsight {
  id          String   @id @default(uuid())
  type        String
  period      String
  content     String
  siteId      String?  @map("site_id")
  generatedAt DateTime @map("generated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  site Site? @relation(fields: [siteId], references: [id])

  @@index([type])
  @@index([generatedAt])
  @@index([siteId])
  @@map("dashboard_insights")
}

/// 구독 플랜
model Plan {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique
  maxWorkers   Int      @map("max_workers")
  maxSites     Int      @default(1) @map("max_sites")
  features     String[]
  priceMonthly Int      @default(0) @map("price_monthly")
  priceYearly  Int      @default(0) @map("price_yearly")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  subscriptions Subscription[]
  @@map("plans")
}

/// 사업장 구독
model Subscription {
  id                 String   @id @default(uuid())
  siteId             String   @map("site_id")
  planId             String   @map("plan_id")
  status             String   @default("ACTIVE")
  billingCycle       String   @default("MONTHLY") @map("billing_cycle")
  trialEndsAt        DateTime? @map("trial_ends_at")
  currentPeriodStart DateTime @default(now()) @map("current_period_start")
  currentPeriodEnd   DateTime @map("current_period_end")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@index([siteId])
  @@index([status])
  @@map("subscriptions")
}

/// 로그인 이력
model LoginHistory {
  id        String   @id @default(uuid())
  workerId  String   @map("worker_id")
  success   Boolean
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  worker Worker @relation(fields: [workerId], references: [id])

  @@index([workerId])
  @@index([createdAt])
  @@map("login_history")
}
