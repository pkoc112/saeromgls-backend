// ============================================
// 작업현황 공유 모바일 - Prisma Schema (SQLite dev / PostgreSQL prod)
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Models ----------

/// 작업자 - 시스템 사용자 (관리자, 반장, 작업자)
model Worker {
  id           String   @id @default(uuid())
  name         String
  employeeCode String   @unique @map("employee_code")
  pin          String   // bcrypt 해시된 PIN
  role         String   @default("WORKER") // ADMIN, SUPERVISOR, WORKER
  status       String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  startedWorkItems WorkItem[]       @relation("StartedBy")
  endedWorkItems   WorkItem[]       @relation("EndedBy")
  assignments      WorkAssignment[]
  auditLogs        AuditLog[]

  @@map("workers")
}

/// 분류 - 작업 분류 코드 (DC, AGENCY, CVS 등)
model Classification {
  id          String   @id @default(uuid())
  code        String   @unique
  displayName String   @map("display_name")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  workItems WorkItem[]

  @@map("classifications")
}

/// 작업 항목 - 핵심 테이블: 작업 시작/종료 기록
model WorkItem {
  id                String   @id @default(uuid())
  startedByWorkerId String   @map("started_by_worker_id")
  classificationId  String   @map("classification_id")
  volume            Float    @default(0) // 물량
  quantity          Int      @default(0) // 수량
  startedAt         DateTime @default(now()) @map("started_at")
  endedAt           DateTime? @map("ended_at")
  status            String   @default("ACTIVE") // ACTIVE, ENDED, VOID
  endedByWorkerId   String?  @map("ended_by_worker_id")
  deviceId          String?  @map("device_id")
  notes             String?
  idempotencyKey    String?  @unique @map("idempotency_key")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  startedByWorker Worker          @relation("StartedBy", fields: [startedByWorkerId], references: [id])
  endedByWorker   Worker?         @relation("EndedBy", fields: [endedByWorkerId], references: [id])
  classification  Classification  @relation(fields: [classificationId], references: [id])
  assignments     WorkAssignment[]
  auditLogs       AuditLog[]

  @@index([status])
  @@index([startedAt])
  @@index([classificationId])
  @@index([startedByWorkerId])
  @@map("work_items")
}

/// 작업 배정 - 작업에 참여하는 작업자 목록
model WorkAssignment {
  id         String   @id @default(uuid())
  workItemId String   @map("work_item_id")
  workerId   String   @map("worker_id")
  role       String   @default("PARTICIPANT") // STARTER, PARTICIPANT
  addedAt    DateTime @default(now()) @map("added_at")

  // Relations
  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  worker   Worker   @relation(fields: [workerId], references: [id])

  @@unique([workItemId, workerId])
  @@map("work_assignments")
}

/// 감사 로그 - 작업 항목 변경 이력
model AuditLog {
  id            String   @id @default(uuid())
  actorWorkerId String   @map("actor_worker_id")
  workItemId    String?  @map("work_item_id")
  action        String   // CREATE, END, EDIT, VOID
  before        String?  // JSON string
  after         String?  // JSON string
  reason        String?
  ip            String?
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  actorWorker Worker    @relation(fields: [actorWorkerId], references: [id])
  workItem    WorkItem? @relation(fields: [workItemId], references: [id], onDelete: SetNull)

  @@index([workItemId])
  @@index([actorWorkerId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// 대시보드 인사이트 - AI 생성 요약 및 이상 탐지 결과
model DashboardInsight {
  id          String   @id @default(uuid())
  type        String   // WEEKLY_SUMMARY, ANOMALY
  period      String   // 예: "2026-W15", "2026-04-01~2026-04-07"
  content     String   // AI 생성 내용
  generatedAt DateTime @map("generated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([type])
  @@index([generatedAt])
  @@map("dashboard_insights")
}
