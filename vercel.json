{
  "version": 2,
  "buildCommand": "npx prisma generate && npx tsc --noEmit && npm run build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "crons": [
    {
      "path": "/api/cron/subscription-check",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/data-retention-purge",
      "schedule": "0 17 1 * *"
    },
    {
      "path": "/api/cron/incentive-monthly-shadow",
      "schedule": "0 18 1 * *"
    },
    {
      "path": "/api/cron/incentive-auto-finalize",
      "schedule": "0 19 * * *"
    }
  ]
}
